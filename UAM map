<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>화성시 UAM vs 구급차 응급 이송 비교 (AI 보정)</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;600;700&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --bg:#0b0f1a;--panel:#111827;--border:#1e2d45;
  --text:#e2e8f0;--muted:#64748b;--accent:#06b6d4;--accent2:#a855f7;
}
body{font-family:'Noto Sans KR',sans-serif;background:var(--bg);color:var(--text);
     height:100vh;display:flex;flex-direction:column;overflow:hidden;}

header{background:var(--panel);border-bottom:1px solid var(--border);
       padding:12px 20px;display:flex;align-items:center;gap:12px;flex-shrink:0;}
header h1{font-size:1rem;font-weight:700;line-height:1.3;}
header h1 span{color:var(--accent);}
.badge{margin-left:auto;background:rgba(6,182,212,.1);border:1px solid rgba(6,182,212,.3);
       color:var(--accent);font-size:.65rem;padding:3px 10px;border-radius:999px;}

.layout{display:flex;flex:1;overflow:hidden;}

aside{width:310px;flex-shrink:0;background:var(--panel);border-right:1px solid var(--border);
      display:flex;flex-direction:column;overflow-y:auto;}
aside::-webkit-scrollbar{width:4px;}
aside::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}

.sec{font-size:.6rem;font-weight:700;letter-spacing:.12em;color:var(--muted);
     text-transform:uppercase;padding:14px 14px 6px;display:flex;align-items:center;justify-content:space-between;}
label.lbl{font-size:.67rem;color:var(--muted);display:block;margin-bottom:3px;}
.irow{padding:0 14px 10px;display:flex;gap:8px;}
.irow>div{flex:1;}
input[type=number],input[type=text],input[type=password],select{
  width:100%;background:#0b0f1a;border:1px solid var(--border);color:var(--text);
  padding:7px 9px;border-radius:7px;font-size:.78rem;outline:none;transition:border-color .2s;}
input:focus,select:focus{border-color:var(--accent);}
select{appearance:none;}

.hosp-item{padding:8px 10px;border-radius:8px;cursor:pointer;transition:all .15s;
           border:1px solid transparent;margin:0 12px 3px;}
.hosp-item:hover{background:rgba(255,255,255,.04);}
.hosp-item.active{background:rgba(168,85,247,.1);border-color:rgba(168,85,247,.4);}
.hosp-name{font-size:.76rem;font-weight:600;}
.hosp-loc{font-size:.63rem;color:var(--muted);margin-top:1px;}

.param-wrap{padding:0 14px 12px;display:flex;flex-direction:column;gap:7px;}

.btn-calc{width:calc(100% - 28px);margin:0 14px 10px;background:var(--accent);color:#0b0f1a;
  border:none;padding:11px;border-radius:9px;font-size:.84rem;font-weight:700;cursor:pointer;
  transition:all .2s;box-shadow:0 4px 14px rgba(6,182,212,.3);}
.btn-calc:hover{opacity:.85;}
.btn-calc:disabled{background:#1e2d45;color:var(--muted);cursor:not-allowed;box-shadow:none;}

.btn-ai{width:calc(100% - 28px);margin:0 14px 14px;background:linear-gradient(135deg,#a855f7,#6366f1);
  color:#fff;border:none;padding:11px;border-radius:9px;font-size:.84rem;font-weight:700;cursor:pointer;
  transition:all .2s;box-shadow:0 4px 14px rgba(168,85,247,.3);}
.btn-ai:hover{opacity:.85;}
.btn-ai:disabled{background:#1e2d45;color:var(--muted);cursor:not-allowed;box-shadow:none;}

.info-box{margin:0 14px 10px;padding:7px 10px;background:#0b0f1a;border:1px solid var(--border);
          border-radius:7px;font-size:.65rem;color:var(--muted);line-height:1.6;}

.result-card{margin:0 14px 10px;border:1px solid var(--border);border-radius:10px;overflow:hidden;display:none;}
.result-card.show{display:block;}
.rrow{display:flex;align-items:center;gap:10px;padding:8px 12px;background:var(--panel);
      border-bottom:1px solid var(--border);}
.rrow:last-child{border-bottom:none;}
.rdot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.rlabel{flex:1;font-size:.7rem;color:var(--muted);}
.rval{font-size:.82rem;font-weight:700;}

.verdict{margin:0 14px 14px;padding:12px 14px;border-radius:10px;text-align:center;
         font-size:.8rem;font-weight:700;line-height:1.7;display:none;}
.verdict.show{display:block;}
.verdict.uam{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);color:#fca5a5;}
.verdict.amb{background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.3);color:#93c5fd;}

.via-badge{margin:0 14px 8px;padding:7px 10px;background:rgba(245,158,11,.08);
           border:1px solid rgba(245,158,11,.3);border-radius:7px;font-size:.7rem;
           color:#fbbf24;display:none;}
.via-badge.show{display:block;}

.hazard-badge{margin:0 14px 8px;padding:7px 10px;background:rgba(249,115,22,.08);
           border:1px solid rgba(249,115,22,.3);border-radius:7px;font-size:.68rem;
           color:#fdba74;display:none;line-height:1.6;}
.hazard-badge.show{display:block;}

.err-box{margin:0 14px 10px;padding:8px 10px;background:rgba(239,68,68,.08);
         border:1px solid rgba(239,68,68,.25);border-radius:7px;font-size:.68rem;
         color:#fca5a5;display:none;line-height:1.5;}
.err-box.show{display:block;}

.ai-box{margin:0 14px 14px;padding:10px 12px;background:rgba(168,85,247,.08);
        border:1px solid rgba(168,85,247,.3);border-radius:9px;font-size:.72rem;
        color:#e9d5ff;display:none;line-height:1.7;white-space:pre-wrap;}
.ai-box.show{display:block;}
.ai-box .ai-title{font-size:.62rem;font-weight:700;letter-spacing:.08em;color:var(--accent2);
        text-transform:uppercase;margin-bottom:6px;display:flex;align-items:center;gap:5px;}

.legend{padding:0 14px 20px;display:flex;flex-direction:column;gap:7px;}
.li{display:flex;align-items:center;gap:10px;font-size:.72rem;color:#94a3b8;}
.ll{width:24px;height:4px;border-radius:2px;flex-shrink:0;}
.ld{width:12px;height:12px;border-radius:50%;flex-shrink:0;}

#map{flex:1;background:#0d1117;}
.leaflet-tile-pane{filter:invert(1) hue-rotate(180deg) brightness(.85) saturate(.9);}
.leaflet-marker-pane,.leaflet-overlay-pane{filter:none!important;}
.leaflet-popup-content-wrapper{background:#1e293b;color:#e2e8f0;border-radius:10px;
  box-shadow:0 4px 20px rgba(0,0,0,.4);border:1px solid #334155;}
.leaflet-popup-tip{background:#1e293b;}
.leaflet-popup-content{margin:10px 14px;font-size:13px;line-height:1.5;}

#overlay{position:fixed;inset:0;background:rgba(11,15,26,.75);display:none;
         align-items:center;justify-content:center;z-index:9999;flex-direction:column;gap:12px;}
#overlay.show{display:flex;}
.spinner{width:38px;height:38px;border:3px solid rgba(6,182,212,.2);
         border-top-color:var(--accent);border-radius:50%;animation:spin .8s linear infinite;}
.spin-label{font-size:.78rem;color:var(--accent);}
@keyframes spin{to{transform:rotate(360deg);}}

details.apikeybox{margin:0 14px 10px;}
details.apikeybox summary{font-size:.68rem;color:var(--muted);cursor:pointer;}
</style>
</head>
<body>

<header>
  <div>
    <h1>화성시 <span>UAM</span> vs 구급차<br>응급 이송 효율 비교 지도</h1>
  </div>
  <span class="badge">OSM · OSRM · Groq AI</span>
</header>

<div class="layout">
<aside>
  <div class="sec">📍 출발지</div>
  <div class="irow">
    <div><label class="lbl">위도</label><input type="number" id="sLat" value="37.2002" step="0.001"/></div>
    <div><label class="lbl">경도</label><input type="number" id="sLng" value="126.8318" step="0.001"/></div>
  </div>
  <div style="padding:0 14px 10px;font-size:.67rem;color:#475569;">💡 지도 클릭으로 출발지 설정 가능</div>

  <div class="sec">🏥 목적지 병원</div>
  <div id="hospList"></div>

  <div class="sec">⚙️ 파라미터 (PDF 기준값)</div>
  <div class="param-wrap">
    <div><label class="lbl">UAM 순항 속도 (km/h) · 한화 버터플라이</label><input type="number" id="uamSpeed" value="200" min="50" max="500"/></div>
    <div><label class="lbl">UAM 이착륙 시간 (분)</label><input type="number" id="uamLand" value="5" min="1" max="30"/></div>
    <div><label class="lbl">구급차 평균 속도 (km/h) · 스타리아 HEV</label><input type="number" id="ambSpeed" value="60" min="20" max="150"/></div>
    <div><label class="lbl">UAM 유리 판정 기준 (분)</label><input type="number" id="thresh" value="5" min="1" max="30"/></div>
  </div>

  <div class="info-box">
    🔴 UAM → 직선 경로 (장애물 무시 비행)<br>
    🚁 UAM 시간 = <b>출동(환승장→환자)</b> + 이송(환자→병원)<br>
    🔵 구급차 → 실제 도로 경로 (OSRM, 화성시 내 실제 굴곡 도로 반영)<br>
    📐 직선 15km 이상 시 환승장 경유<br>
    🟠 상습정체 교차로 / 🟣 사고다발구간 통과 시<br>&nbsp;&nbsp;구급차 시간에 지연 가산 (탐구보고서 사진1·2 기반)
  </div>

  <button class="btn-calc" id="btnCalc" onclick="calculate()">🚀 경로 분석 시작</button>

  <details class="apikeybox">
    <summary>🔑 Groq API 설정</summary>
    <div style="padding:8px 0 0;display:flex;flex-direction:column;gap:7px;">
      <div><label class="lbl">Groq API Key</label>
        <input type="text" autocomplete="off" spellcheck="false" id="groqKey" placeholder="API 키를 입력하세요"
          oninput="document.getElementById('keyLenHint').textContent='현재 입력된 글자 수: '+this.value.replace(/\s+/g,'').length+'자';"/>
        <div id="keyLenHint" style="font-size:.6rem;color:#475569;margin-top:3px;">현재 입력된 글자 수: 0자</div>
      </div>
      <div><label class="lbl">모델</label>
        <select id="groqModel">
          <option value="llama-3.3-70b-versatile">llama-3.3-70b-versatile</option>
          <option value="llama-3.1-8b-instant">llama-3.1-8b-instant</option>
          <option value="deepseek-r1-distill-llama-70b">deepseek-r1-distill-llama-70b</option>
        </select>
      </div>
      <div style="font-size:.62rem;color:var(--muted);line-height:1.5;">
        API 키는 브라우저에서만 사용되며 저장/전송되지 않습니다.<br>
        console.groq.com 에서 무료 발급 가능.
      </div>
    </div>
  </details>

  <button class="btn-ai" id="btnAI" onclick="runAIcorrection()" disabled>🤖 AI로 예상시간 보정 + 최종 판정</button>

  <div class="err-box" id="errBox"></div>

  <div class="sec">📊 분석 결과 (규칙 기반)</div>
  <div class="via-badge" id="viaBadge"></div>
  <div class="hazard-badge" id="hazardBadge"></div>
  <div class="result-card" id="resCard">
    <div class="rrow"><div class="rdot" style="background:#fbbf24"></div><div class="rlabel">UAM 출동(픽업) 시간</div><div class="rval" id="rDispatch">—</div></div>
    <div class="rrow"><div class="rdot" style="background:#ef4444"></div><div class="rlabel">UAM 총 예상 시간</div><div class="rval" id="rUam">—</div></div>
    <div class="rrow"><div class="rdot" style="background:#3b82f6"></div><div class="rlabel">구급차 예상 시간</div><div class="rval" id="rAmb">—</div></div>
    <div class="rrow"><div class="rdot" style="background:#f97316"></div><div class="rlabel">정체/사고구역 지연 가산</div><div class="rval" id="rHazMin">—</div></div>
    <div class="rrow"><div class="rdot" style="background:#64748b"></div><div class="rlabel">시간 차이</div><div class="rval" id="rDiff">—</div></div>
    <div class="rrow"><div class="rdot" style="background:#ef4444"></div><div class="rlabel">UAM 직선 거리</div><div class="rval" id="rStraight">—</div></div>
    <div class="rrow"><div class="rdot" style="background:#3b82f6"></div><div class="rlabel">구급차 도로 거리</div><div class="rval" id="rRoad">—</div></div>
  </div>
  <div class="verdict" id="verdict"></div>

  <div class="sec">🤖 AI 보정 결과 (Groq)</div>
  <div class="ai-box" id="aiBox"></div>

  <div class="sec">🗺️ 범례</div>
  <div class="legend">
    <div class="li"><div class="ll" style="background:#ef4444"></div>UAM 직선 경로</div>
    <div class="li"><div class="ll" style="background:#3b82f6"></div>구급차 도로 경로</div>
    <div class="li"><div class="ld" style="background:#22c55e"></div>출발지</div>
    <div class="li"><div class="ld" style="background:#a855f7"></div>목적지 병원</div>
    <div class="li"><div class="ld" style="background:#f59e0b"></div>UAM 환승 지점</div>
    <div class="li"><div class="ld" style="background:#f97316"></div>상습 정체 교차로</div>
    <div class="li"><div class="ld" style="background:#dc2626"></div>사고다발 구간</div>
    <div class="li"><div class="ld" style="background:#84cc16"></div>일차선/농촌 도로 구간</div>
  </div>
</aside>

<div id="map"></div>
</div>

<div id="overlay">
  <div class="spinner"></div>
  <div class="spin-label" id="spinLabel">도로 경로 불러오는 중…</div>
</div>

<script>
// ══════════════════════════════════════════════
// 데이터 (탐구보고서 + 웹 조사 기반)
// ══════════════════════════════════════════════
const HOSPITALS = [
  {id:1,name:"한림대동탄성심병원",loc:"동탄",   lat:37.2055,lng:127.0798},
  {id:2,name:"화성시의료원",      loc:"남양읍", lat:37.2032,lng:126.8125},
  {id:3,name:"봉담성모병원",      loc:"봉담읍", lat:37.2188,lng:126.9801},
  {id:4,name:"화성중앙병원",      loc:"향남읍", lat:37.0701,lng:126.9742},
];

const TRANSFERS = [
  {name:"동탄 버티포트(가칭)",         lat:37.2010,lng:127.0750},
  {name:"향남읍 한두골길 환승장(구 쓰레기처리장 부지)", lat:37.0658,lng:126.9187},
  {name:"매송면 야목리 환승장(휴게소 인근)",           lat:37.2199,lng:126.8965},
  {name:"제부도 환승장(헬기장)",         lat:37.1730,lng:126.6691},
];
const TRANSFER_KM = 15;

const CONGESTION_ZONES = [
  {name:"동탄역 사거리(치동중 인근·1번국도)", lat:37.2005, lng:127.0958, r:600,
   note:"보고서 사진1 지점. 사방 합류 + 버스 통행량 과다로 상시 정체"},
  {name:"병점사거리(효행로×태안로, 병점역 인근)", lat:37.2064, lng:127.0328, r:500,
   note:"출퇴근 시간 극심한 정체 구간"},
  {name:"봉담IC 교차로(향남·봉담 고속화도로 합류)", lat:37.2075, lng:126.9803, r:500,
   note:"고속도로 진출입 차량 합류로 상습 정체"},
  {name:"향남터미널사거리", lat:37.0701, lng:126.9742, r:450,
   note:"향남읍 중심 상권 진입로, 화물차 혼재"},
  {name:"남양읍사무소사거리(시청 인근)", lat:37.2032, lng:126.8125, r:400,
   note:"남양읍 중심가 병목"},
];

const ACCIDENT_ZONES = [
  {name:"매송IC 부근(서해안고속도로 진입)", lat:37.2199, lng:126.8965, r:700,
   note:"고속도로 합류 구간 사고다발"},
  {name:"향남산업단지 진입로", lat:37.0620, lng:126.9430, r:600,
   note:"대형 화물차 통행량 많아 사고 위험 높음"},
  {name:"봉담IC~향남 고속화도로 구간", lat:37.1450, lng:126.9600, r:800,
   note:"고속 주행 구간, 야간 사고 다발"},
];

const RURAL_ZONES = [
  {name:"서신면 일대(제부도 방면 일차선 농로)", lat:37.1980, lng:126.6900, r:1500},
  {name:"향남읍 외곽 농경지(발안 서편)", lat:37.0500, lng:126.8900, r:1500},
  {name:"매송면 농촌 지역", lat:37.2300, lng:126.8500, r:1200},
];

let selHosp = HOSPITALS[0];
let startMarker=null, hospMarker=null;
let uamLayer=null, ambLayer=null, txHighlight=null, txMarkers=[];
let lastCalc=null;

const map = L.map('map',{center:[37.17,126.93],zoom:11});
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{
  attribution:'© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',maxZoom:19
}).addTo(map);

function mkIcon(color,emoji,sz){
  sz=sz||34;
  return L.divIcon({className:'',iconSize:[sz,sz],iconAnchor:[sz/2,sz/2],
    html:`<div style="width:${sz}px;height:${sz}px;border-radius:50%;background:${color};
      border:3px solid rgba(255,255,255,.9);display:flex;align-items:center;justify-content:center;
      font-size:${sz*.42}px;box-shadow:0 2px 14px rgba(0,0,0,.6);">${emoji}</div>`});
}

function drawTransfers(){
  txMarkers.forEach(m=>map.removeLayer(m));
  txMarkers=[];
  TRANSFERS.forEach(t=>{
    const m=L.marker([t.lat,t.lng],{icon:mkIcon('#f59e0b','✈',30)})
      .addTo(map)
      .bindPopup(`<b>${t.name}</b><br><span style="color:#94a3b8;font-size:11px">UAM 환승 지점</span>`);
    txMarkers.push(m);
  });
}
drawTransfers();

function drawHazardZones(){
  CONGESTION_ZONES.forEach(z=>{
    L.circle([z.lat,z.lng],{radius:z.r,color:'#f97316',weight:2,fillColor:'#f97316',fillOpacity:.15})
      .addTo(map).bindPopup(`🟠 <b>상습 정체 교차로</b><br>${z.name}<br><span style="color:#94a3b8;font-size:11px">${z.note}</span>`);
    L.marker([z.lat,z.lng],{icon:mkIcon('#f97316','🚦',24)}).addTo(map)
      .bindPopup(`🟠 <b>상습 정체 교차로</b><br>${z.name}`);
  });
  ACCIDENT_ZONES.forEach(z=>{
    L.circle([z.lat,z.lng],{radius:z.r,color:'#dc2626',weight:2,fillColor:'#dc2626',fillOpacity:.12,dashArray:'4 4'})
      .addTo(map).bindPopup(`🔴 <b>사고다발 구간</b><br>${z.name}<br><span style="color:#94a3b8;font-size:11px">${z.note}</span>`);
  });
  RURAL_ZONES.forEach(z=>{
    L.circle([z.lat,z.lng],{radius:z.r,color:'#84cc16',weight:1.5,fillColor:'#84cc16',fillOpacity:.08,dashArray:'2 6'})
