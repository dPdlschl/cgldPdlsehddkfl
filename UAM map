function hav(la1,lo1,la2,lo2){
  const R=6371, dL=(la2-la1)*Math.PI/180, dO=(lo2-lo1)*Math.PI/180;
  const a=Math.sin(dL/2)**2+Math.cos(la1*Math.PI/180)*Math.cos(la2*Math.PI/180)*Math.sin(dO/2)**2;
  return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
}

function pointNearZone(la,lo,zone){
  return hav(la,lo,zone.lat,zone.lng)*1000 <= zone.r*1.15;
}

function detectHazardsOnRoute(coords){
  const hit={congestion:[],accident:[],rural:[]};
  if(!coords||!coords.length) return hit;
  const sample = coords.filter((_,i)=>i%3===0);
  CONGESTION_ZONES.forEach(z=>{ if(sample.some(([la,lo])=>pointNearZone(la,lo,z))) hit.congestion.push(z); });
  ACCIDENT_ZONES.forEach(z=>{ if(sample.some(([la,lo])=>pointNearZone(la,lo,z))) hit.accident.push(z); });
  RURAL_ZONES.forEach(z=>{ if(sample.some(([la,lo])=>pointNearZone(la,lo,z))) hit.rural.push(z); });
  return hit;
}

async function fetchRoad(la1,lo1,la2,lo2){
  // 화성시 내부의 구불구불한 실제 도로망을 OSRM 라우팅 엔진이 OpenStreetMap 도로 그래프
  // 기준으로 실시간 계산하도록, 여러 미러 서버를 순서대로 시도하고 서버당 최대 2회 재시도한다.
  const endpoints=[
    `https://router.project-osrm.org/route/v1/driving/${lo1},${la1};${lo2},${la2}?overview=full&geometries=geojson&steps=false`,
    `https://routing.openstreetmap.de/routed-car/route/v1/driving/${lo1},${la1};${lo2},${la2}?overview=full&geometries=geojson&steps=false`,
    `https://osrm.router.place/route/v1/driving/${lo1},${la1};${lo2},${la2}?overview=full&geometries=geojson&steps=false`,
  ];
  let lastErr=null;
  for(const url of endpoints){
    for(let attempt=0; attempt<2; attempt++){
      try{
        const r=await fetch(url,{signal:AbortSignal.timeout(15000)});
        if(!r.ok){ lastErr=new Error(`HTTP ${r.status}`); continue; }
        const d=await r.json();
        if(!d.routes||!d.routes.length){ lastErr=new Error('경로 없음'); continue; }
        const rt=d.routes[0];
        // 실제 도로 형상(다수의 좌표점)을 그대로 반환 → 화성시의 구불구불한 도로가 폴리라인에 정밀 반영됨
        return{ km: rt.distance/1000, coords: rt.geometry.coordinates.map(([lo,la])=>[la,lo]) };
      }catch(e){ lastErr=e; }
    }
  }
  throw lastErr||new Error('모든 라우팅 서버 실패');
}

function nearTx(la,lo){
  let best=null,bd=Infinity;
  TRANSFERS.forEach(t=>{ const d=hav(la,lo,t.lat,t.lng); if(d<bd){bd=d;best=t;} });
  return best;
}

function clearRoutes(){
  if(uamLayer){map.removeLayer(uamLayer);uamLayer=null;}
  if(ambLayer){map.removeLayer(ambLayer);ambLayer=null;}
  if(txHighlight){map.removeLayer(txHighlight);txHighlight=null;}
}

function showErr(msg){ const b=document.getElementById('errBox'); b.textContent=msg; b.classList.add('show'); }
function hideErr(){ document.getElementById('errBox').classList.remove('show'); }
function setSpinLabel(t){ document.getElementById('spinLabel').textContent=t; }

async function calculate(){
  const sLat=parseFloat(document.getElementById('sLat').value);
  const sLng=parseFloat(document.getElementById('sLng').value);
  if(isNaN(sLat)||isNaN(sLng)){alert('출발지를 설정해주세요.');return;}

  const dLat=selHosp.lat, dLng=selHosp.lng;
  const uamSpd=parseFloat(document.getElementById('uamSpeed').value)||200;
  const uamLnd=parseFloat(document.getElementById('uamLand').value)||5;
  const ambSpd=parseFloat(document.getElementById('ambSpeed').value)||60;
  const thresh=parseFloat(document.getElementById('thresh').value)||5;

  setStart(sLat,sLng);
  setHosp(selHosp);
  clearRoutes();
  hideErr();
  document.getElementById('resCard').classList.remove('show');
  document.getElementById('verdict').classList.remove('show');
  document.getElementById('viaBadge').classList.remove('show');
  document.getElementById('hazardBadge').classList.remove('show');
  document.getElementById('aiBox').classList.remove('show');
  document.getElementById('overlay').classList.add('show');
  document.getElementById('btnCalc').disabled=true;
  document.getElementById('btnAI').disabled=true;

  try{
    setSpinLabel('🔵 구급차 도로 경로 불러오는 중…');
    let ambKm, ambMin, ambCoords=[];
    let roadOk=false;
    try{
      const a=await fetchRoad(sLat,sLng,dLat,dLng);
      ambKm=a.km; ambCoords=a.coords; ambMin=(ambKm/ambSpd)*60; roadOk=true;
    }catch(e){
      ambKm=hav(sLat,sLng,dLat,dLng)*1.4;
      ambMin=(ambKm/ambSpd)*60;
      showErr('⚠️ 도로 데이터를 불러오지 못했습니다. 직선거리×1.4로 구급차 거리를 추정합니다.');
    }

    const hazards = detectHazardsOnRoute(ambCoords);
    let hazMin = hazards.congestion.length*4 + hazards.accident.length*3 + hazards.rural.length*2;
    ambMin += hazMin;

    const straight=hav(sLat,sLng,dLat,dLng);
    const via=straight>=TRANSFER_KM;
    let uamMin, tx=null;
    let uamCoords=[];

    // ── 🚁 UAM 출동(디스패치) 시간: 가장 가까운 환승장(버티포트)에서 대기 중이던 UAM이
    //    환자 위치까지 날아와서 착륙·환자 탑승을 완료하는 시간까지 반드시 포함한다 ──
    setSpinLabel('🔴 가장 가까운 환승장에서 UAM 출동 중…');
    const dispatchTx = nearTx(sLat,sLng);           // 환자와 가장 가까운 환승장(버티포트)
    const dispatchKm = hav(dispatchTx.lat,dispatchTx.lng,sLat,sLng);
    const dispatchMin = (dispatchKm/uamSpd)*60 + uamLnd; // 출동 비행시간 + 착륙/환자탑승 시간

    if(via){
      tx=nearTx(sLat,sLng); // 이송(하강)용 환승장도 동일하게 환자 인근 환승장 사용
      setSpinLabel('🔴 UAM 환승 경로 계산 중…');
      const fromTxKm=hav(tx.lat,tx.lng,dLat,dLng);
      let toTxMin;
      try{
        setSpinLabel('🔴 환승장까지 도로 경로 계산 중…');
        const seg=await fetchRoad(sLat,sLng,tx.lat,tx.lng);
        toTxMin=(seg.km/ambSpd)*60;
        const segHaz=detectHazardsOnRoute(seg.coords);
        toTxMin += segHaz.congestion.length*4 + segHaz.accident.length*3 + segHaz.rural.length*2;
      }catch{
        const toTxKm=hav(sLat,sLng,tx.lat,tx.lng);
        toTxMin=(toTxKm*1.4/ambSpd)*60;
      }
      const flightMin=(fromTxKm/uamSpd)*60;
      uamMin=dispatchMin+toTxMin+uamLnd+flightMin;
      uamCoords=[[dispatchTx.lat,dispatchTx.lng],[sLat,sLng],[tx.lat,tx.lng],[dLat,dLng]];
    }else{
      uamMin=dispatchMin+(straight/uamSpd)*60+uamLnd;
      uamCoords=[[dispatchTx.lat,dispatchTx.lng],[sLat,sLng],[dLat,dLng]];
    }

    const diff=ambMin-uamMin;
    const uamWin=diff>=thresh;

    if(ambCoords.length>1){
      ambLayer=L.polyline(ambCoords,{
        color:'#3b82f6', weight: uamWin?4:6, opacity: uamWin?0.5:0.95,
        dashArray: uamWin?'8 5':null, lineJoin:'round', lineCap:'round'
      }).addTo(map)
        .bindPopup(`🚑 <b>구급차</b><br>도로 거리: ${ambKm.toFixed(1)}km<br>예상 시간: ${ambMin.toFixed(1)}분 (지연가산 ${hazMin}분 포함)`);
    }else if(!roadOk){
      ambLayer=L.polyline([[sLat,sLng],[dLat,dLng]],{color:'#3b82f6',weight:4,opacity:0.5,dashArray:'6 8'})
        .addTo(map).bindPopup(`🚑 구급차 추정: ${ambMin.toFixed(1)}분 (도로 데이터 없음)`);
    }

    uamLayer=L.polyline(uamCoords,{
      color:'#ef4444', weight: uamWin?6:4, opacity: uamWin?0.95:0.5,
      dashArray: uamWin?null:'8 5', lineJoin:'round', lineCap:'round'
    }).addTo(map)
      .bindPopup(`🚁 <b>UAM</b><br>출동 환승장: ${dispatchTx.name}<br>출동(환자 픽업) 시간: ${dispatchMin.toFixed(1)}분<br>직선 거리(환자→병원): ${straight.toFixed(1)}km<br>총 예상 시간: ${uamMin.toFixed(1)}분`);

    if(via && tx){
      txHighlight=L.circleMarker([tx.lat,tx.lng],{radius:20,color:'#ef4444',weight:3,fillColor:'#fef3c7',fillOpacity:.5})
        .addTo(map).bindPopup(`🔁 환승: ${tx.name}`);
    }

    const bounds=[[sLat,sLng],[dLat,dLng]];
    if(via&&tx) bounds.push([tx.lat,tx.lng]);
    if(ambCoords.length) ambCoords.forEach(c=>bounds.push(c));
    map.fitBounds(bounds,{padding:[60,60]});

    document.getElementById('rDispatch').textContent=`${dispatchMin.toFixed(1)}분 (${dispatchTx.name})`;
    document.getElementById('rUam').textContent=`${uamMin.toFixed(1)}분`;
    document.getElementById('rAmb').textContent=`${ambMin.toFixed(1)}분`;
    document.getElementById('rHazMin').textContent=`+${hazMin}분`;
    document.getElementById('rDiff').textContent=`${Math.abs(diff).toFixed(1)}분`;
    document.getElementById('rStraight').textContent=`${straight.toFixed(1)}km`;
    document.getElementById('rRoad').textContent=roadOk?`${ambKm.toFixed(1)}km`:`~${ambKm.toFixed(1)}km (추정)`;
    document.getElementById('resCard').classList.add('show');

    if(via){
      const vb=document.getElementById('viaBadge');
      vb.textContent=`✈ ${tx.name} 경유`;
      vb.classList.add('show');
    }

    const totalHaz = hazards.congestion.length+hazards.accident.length+hazards.rural.length;
    if(totalHaz>0){
      const hb=document.getElementById('hazardBadge');
      const parts=[];
      if(hazards.congestion.length) parts.push(`🟠정체 ${hazards.congestion.length}곳`);
      if(hazards.accident.length) parts.push(`🔴사고다발 ${hazards.accident.length}곳`);
      if(hazards.rural.length) parts.push(`🟢농촌/일차선 ${hazards.rural.length}곳`);
      hb.textContent='⚠ 구급차 경로 통과 위험구역: '+parts.join(', ');
      hb.classList.add('show');
    }

    const vd=document.getElementById('verdict');
    vd.className='verdict show '+(uamWin?'uam':'amb');
    vd.innerHTML=uamWin
      ?`🚁 UAM이 <b>${Math.abs(diff).toFixed(1)}분</b> 빠릅니다<br>UAM 유리 구간`
      :`🚑 구급차가 <b>${Math.abs(diff).toFixed(1)}분</b> 빠릅니다<br>구급차 유리 구간`;

    lastCalc={
      start:{lat:sLat,lng:sLng}, hospital:selHosp,
      uamMin, ambMin, hazMin, diff, uamWin,
      dispatchTx:dispatchTx.name, dispatchKm, dispatchMin,
      straightKm:straight, roadKm:ambKm, roadOk,
      via, transfer: tx?tx.name:null,
      hazards:{
        congestion:hazards.congestion.map(z=>z.name),
        accident:hazards.accident.map(z=>z.name),
        rural:hazards.rural.map(z=>z.name)
      },
      params:{uamSpd,uamLnd,ambSpd,thresh}
    };
    document.getElementById('btnAI').disabled=false;

  }catch(e){
    console.error(e);
    showErr('오류: '+e.message);
  }

  document.getElementById('overlay').classList.remove('show');
  document.getElementById('btnCalc').disabled=false;
}

async function runAIcorrection(){
  if(!lastCalc){ alert('먼저 "경로 분석 시작"을 눌러 계산을 완료해주세요.'); return; }
  const apiKey=document.getElementById('groqKey').value.replace(/\s+/g,'').trim();
  if(!apiKey){ alert('Groq API Key를 입력해주세요. (console.groq.com에서 무료 발급)\n\n※ 붙여넣기가 안 되면 입력칸을 클릭한 뒤 직접 Ctrl+V로 다시 시도해보세요.'); return; }
  const model=document.getElementById('groqModel').value;

  const aiBox=document.getElementById('aiBox');
  aiBox.classList.add('show');
  aiBox.innerHTML='<div class="ai-title">🤖 GROQ AI 분석중…</div>AI가 정체/사고구역 데이터를 반영해 예상시간을 보정하고 있습니다...';
  document.getElementById('btnAI').disabled=true;

  const c=lastCalc;
  const systemPrompt=`너는 대한민국 화성시의 응급의료 이송 전문가이자 교통 데이터 분석가다.
아래 규칙기반 계산 결과와 통과 위험구역 정보를 바탕으로, 실제 상황을 고려한 "보정된 예상 소요시간"과
UAM(도심항공모빌리티) vs 구급차(현대 스타리아 하이브리드) 중 어느 이송수단이 더 유리한지 최종 판정을 내려라.
고려 요소: 상습정체교차로/사고다발구간/일차선농촌도로를 통과하는 구급차는 규칙기반보다 추가로 지연될 가능성,
UAM은 기상(강풍/우천 시 결항 가능성)과 이착륙장 접근성 리스크가 있음을 함께 감안하라.
답변은 반드시 한국어로, 아래 형식을 지켜 간결하게 작성하라(마크다운 기호 사용 금지, 순수 텍스트):

[보정 결과]
- UAM 보정 예상시간: (분)
- 구급차 보정 예상시간: (분)
- 최종 판정: (UAM 유리 / 구급차 유리) - 이유 한 줄

[상세 분석]
(3~5줄로 위험구역 통과 영향, 리스크 요인, 판단 근거 서술)

[권고사항]
(1~2줄로 실무적 제안)`;

  const userPrompt=`[규칙기반 계산 결과]
출발지: 위도 ${c.start.lat}, 경도 ${c.start.lng}
목적지 병원: ${c.hospital.name} (${c.hospital.loc})
UAM 출동 환승장(가장 가까운 버티포트): ${c.dispatchTx} / 출동거리: ${c.dispatchKm.toFixed(1)}km / 출동(환자 픽업) 소요시간: ${c.dispatchMin.toFixed(1)}분 (이미 아래 총 예상시간에 포함됨)
UAM 직선거리(환자→병원): ${c.straightKm.toFixed(1)}km / UAM 총 예상시간(출동+이송, 규칙기반): ${c.uamMin.toFixed(1)}분
구급차 도로거리: ${c.roadKm.toFixed(1)}km (${c.roadOk?'실제 도로데이터':'추정치'}) / 구급차 예상시간(규칙기반, 지연가산 포함): ${c.ambMin.toFixed(1)}분
구급차 경로에 반영된 지연 가산: ${c.hazMin}분
UAM 환승 경유 여부: ${c.via? '경유 ('+c.transfer+')' : '직항'}
구급차 경로가 통과하는 상습정체 교차로: ${c.hazards.congestion.length? c.hazards.congestion.join(', ') : '없음'}
구급차 경로가 통과하는 사고다발구간: ${c.hazards.accident.length? c.hazards.accident.join(', ') : '없음'}
구급차 경로가 통과하는 일차선/농촌 도로구간: ${c.hazards.rural.length? c.hazards.rural.join(', ') : '없음'}
파라미터: UAM속도 ${c.params.uamSpd}km/h, UAM이착륙 ${c.params.uamLnd}분, 구급차속도 ${c.params.ambSpd}km/h, UAM유리판정기준 ${c.params.thresh}분

위 데이터를 바탕으로 보정 분석과 최종 판정을 제시해줘.`;

  try{
    const res=await fetch('https://api.groq.com/openai/v1/chat/completions',{
      method:'POST',
      headers:{ 'Content-Type':'application/json', 'Authorization':'Bearer '+apiKey },
      body:JSON.stringify({
        model,
        messages:[
          {role:'system',content:systemPrompt},
          {role:'user',content:userPrompt}
        ],
        temperature:0.4,
        max_tokens:700
      })
    });
    if(!res.ok){
      const errText=await res.text();
      throw new Error(`Groq API 오류 (${res.status}): ${errText.slice(0,200)}`);
    }
    const data=await res.json();
    const answer=data.choices?.[0]?.message?.content || 'AI 응답을 받지 못했습니다.';
    aiBox.innerHTML='<div class="ai-title">🤖 GROQ AI 보정 분석 (모델: '+model+')</div>'+answer.replace(/</g,'&lt;');
  }catch(e){
    console.error(e);
    aiBox.innerHTML='<div class="ai-title">⚠ 오류</div>AI 분석 중 오류가 발생했습니다: '+e.message+
      '<br><br>· API Key가 올바른지, console.groq.com에서 발급받은 키인지 확인해주세요.<br>· 브라우저 콘솔(F12)에서 CORS 관련 오류 여부도 확인해보세요.';
  }
  document.getElementById('btnAI').disabled=false;
}
